# ===== Server =====
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ===== Auth =====
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# ===== Database =====
# SQLite file path (relative to backend/). No external DB server required.
DB_PATH=./data/app.db

# ===== LLM (used for pre-visit and post-visit AI summaries) =====
# Works with any OpenAI-compatible endpoint (OpenAI, Groq, OpenRouter, etc.)
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
# If LLM_API_KEY is left blank, the service automatically falls back to a
# deterministic mock summarizer so the app never breaks (see llm.service.js)

# ===== Email (Nodemailer - works with SendGrid, Gmail SMTP, Mailtrap, etc.) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM="Clinic Manager <no-reply@clinic.com>"
# If SMTP_USER/SMTP_PASS are left blank, emails are logged to console/DB
# instead of being sent (dev-safe fallback, retried by background job)

# ===== Google Calendar (OAuth 2.0) =====
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/calendar/oauth/callback

# ===== Background Jobs =====
# Cron expression for medication reminder + email retry sweep
REMINDER_CRON=*/5 * * * *
